// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (string)
// Fields:
//   - username: string (required) - Login username
//   - name: string (required) - Full name
//   - role: string (required, enum: ADMIN, STAF_MASUK, STAF_KELUAR) - User role
//   - password: string (required) - User password
//
// Collection: letters
// Document ID: letterId (string)
// Fields:
//   - type: string (required, enum: INCOMING, OUTGOING)
//   - referenceNumber: string (required)
//   - date: string (required)
//   - sender: string (required)
//   - subject: string (required)
//   - description: string (optional)
//   - scannedImages: list (optional)
//   - disposition: map (optional)
//   - check1: bool (optional)
//   - check2: bool (optional)
//   - createdAt: number (required)
//   - createdBy: string (optional)
//
// Collection: agendas
// Document ID: agendaId (string)
// Fields:
//   - dayDate: string (required)
//   - items: list (required)
//   - signedBy: string (optional)
//   - signedNip: string (optional)
//   - createdAt: number (required)
//   - createdBy: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Heartbeat / Connection Test
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && (
        (request.auth.token.email == "noviharyanto062@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "ADMIN")
      );
    }

    function hasRole(role) {
      return isVerified() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 && data.username.size() <= 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role in ['ADMIN', 'STAF_MASUK', 'STAF_KELUAR'] &&
             data.password is string && data.password.size() > 0 && data.password.size() <= 128;
    }

    function isValidLetter(data) {
      return data.type in ['INCOMING', 'OUTGOING'] &&
             data.referenceNumber is string && data.referenceNumber.size() <= 100 &&
             data.date is string && data.date.size() <= 50 &&
             data.sender is string && data.sender.size() <= 200 &&
             data.subject is string && data.subject.size() <= 500 &&
             data.createdAt is number &&
             (!('scannedImages' in data) || data.scannedImages is list) &&
             (!('disposition' in data) || data.disposition is map) &&
             (!('description' in data) || data.description is string);
    }

    function isValidAgenda(data) {
      return data.dayDate is string && data.dayDate.size() <= 50 &&
             data.items is list && data.items.size() <= 100 &&
             data.createdAt is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isVerified();
      
      allow create: if (isAdmin() || request.auth.uid == userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming());
                      
      allow update: if (isAdmin() || request.auth.uid == userId) && 
                      isValidUser(incoming()) &&
                      (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'password', 'role', 'username']) || isAdmin());
      
      allow delete: if isAdmin();
    }

    match /letters/{letterId} {
      allow get: if isVerified();
      allow list: if isVerified();
      
      allow create: if isVerified() && isValidId(letterId) && isValidLetter(incoming()) && (
        isAdmin() || 
        (incoming().type == 'INCOMING' && hasRole('STAF_MASUK')) ||
        (incoming().type == 'OUTGOING' && hasRole('STAF_KELUAR'))
      );
      
      allow update: if isVerified() && isValidLetter(incoming()) && (
        isAdmin() || 
        (existing().type == 'INCOMING' && hasRole('STAF_MASUK')) ||
        (existing().type == 'OUTGOING' && hasRole('STAF_KELUAR'))
      ) && incoming().type == existing().type; // Type is immutable
      
      allow delete: if isAdmin();
    }

    match /agendas/{agendaId} {
      allow read: if isVerified();
      allow create, update: if isAdmin() && isValidId(agendaId) && isValidAgenda(incoming());
      allow delete: if isAdmin();
    }
  }
}
